<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1118"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 헤더 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="내 건강 리포트"
            android:textSize="20sp"
            android:textColor="#2E75B6"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvWorkerId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="작업자: --"
            android:textSize="12sp"
            android:textColor="#7A8FA3"
            android:layout_marginBottom="16dp" />

        <!-- 현재 베이스라인 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="학습된 내 기준값"
            android:textSize="14sp"
            android:textColor="#E0E6ED"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- 안정 시 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#111D29"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="안정 시"
                    android:textSize="10sp"
                    android:textColor="#7A8FA3" />

                <TextView
                    android:id="@+id/tvRestHr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- bpm"
                    android:textSize="24sp"
                    android:textColor="#43A047"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRestRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="범위: --~--"
                    android:textSize="10sp"
                    android:textColor="#5A7A96" />
            </LinearLayout>

            <!-- 활동 시 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#111D29"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="활동 시"
                    android:textSize="10sp"
                    android:textColor="#7A8FA3" />

                <TextView
                    android:id="@+id/tvActiveHr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- bpm"
                    android:textSize="24sp"
                    android:textColor="#2E75B6"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvActiveRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="범위: --~--"
                    android:textSize="10sp"
                    android:textColor="#5A7A96" />
            </LinearLayout>
        </LinearLayout>

        <!-- 학습 현황 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="학습 현황"
            android:textSize="14sp"
            android:textColor="#E0E6ED"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111D29"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvLearningDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="총 학습 기간: --일"
                android:textSize="13sp"
                android:textColor="#E0E6ED"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvLearningRecords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="기록 수: --건"
                android:textSize="13sp"
                android:textColor="#E0E6ED"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvWorkType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="작업 유형: --"
                android:textSize="13sp"
                android:textColor="#E0E6ED"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="현재 민감도: --"
                android:textSize="13sp"
                android:textColor="#E0E6ED" />
        </LinearLayout>

        <!-- 시간대별 패턴 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="시간대별 패턴"
            android:textSize="14sp"
            android:textColor="#E0E6ED"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/timeSlotContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111D29"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvMorning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌅 오전 (06~12): 데이터 없음"
                android:textSize="12sp"
                android:textColor="#E0E6ED"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvAfternoon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="☀ 오후 (12~18): 데이터 없음"
                android:textSize="12sp"
                android:textColor="#E0E6ED"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvEvening"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌆 저녁 (18~22): 데이터 없음"
                android:textSize="12sp"
                android:textColor="#E0E6ED"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvNight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌙 야간 (22~06): 데이터 없음"
                android:textSize="12sp"
                android:textColor="#E0E6ED" />
        </LinearLayout>

        <!-- 알림 기준 설명 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="이상 알림 기준"
            android:textSize="14sp"
            android:textColor="#E0E6ED"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111D29"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvAlertThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="안정 시 이상: -- bpm 초과\n활동 시 이상: -- bpm 초과\nSpO₂: 93% 이하\n낙상: 자유낙하+충격 패턴"
                android:textSize="12sp"
                android:textColor="#B0BEC5"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- 개인정보 안내 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0D2137"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔒 개인정보 보호"
                android:textSize="12sp"
                android:textColor="#43A047"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="이 데이터는 본인만 열람 가능합니다.\n관제센터에는 AI 분석 결과(위험도/피로도)만 전달됩니다.\n원시 생체 데이터는 워치 내부에서 처리됩니다."
                android:textSize="10sp"
                android:textColor="#7A8FA3"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
