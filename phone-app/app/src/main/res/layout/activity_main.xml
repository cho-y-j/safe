<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1118"
    android:padding="20dp">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="#2E75B6"
            android:text="SP"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SafePulse 관리"
                android:textSize="18sp"
                android:textColor="#E0E6ED"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvConnectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○ 워치 연결 대기"
                android:textSize="12sp"
                android:textColor="#FFB74D" />
        </LinearLayout>
    </LinearLayout>

    <!-- 워치 상태 카드 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111D29"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="워치 상태"
            android:textSize="12sp"
            android:textColor="#7A8FA3"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvWorkerId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="20sp"
                    android:textColor="#E0E6ED"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="작업자 ID"
                    android:textSize="10sp"
                    android:textColor="#5A7A96" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvWatchStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="대기"
                    android:textSize="20sp"
                    android:textColor="#FFB74D"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="상태"
                    android:textSize="10sp"
                    android:textColor="#5A7A96" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvSignal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="20sp"
                    android:textColor="#7A8FA3"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="신호"
                    android:textSize="10sp"
                    android:textColor="#5A7A96" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 내 건강 리포트 버튼 -->
    <Button
        android:id="@+id/btnHealth"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="📊 내 건강 리포트"
        android:textSize="14sp"
        android:textColor="#2E75B6"
        android:backgroundTint="#111D29"
        android:layout_marginBottom="8dp" />

    <!-- 큰 확인 버튼 (이상 감지 시 사용) -->
    <Button
        android:id="@+id/btnAck"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:text="✅ 괜찮아요 (이상 없음)"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#43A047"
        android:layout_marginBottom="12dp"
        android:visibility="gone" />

    <!-- 관제센터 메시지 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111D29"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 관제센터 알림"
            android:textSize="12sp"
            android:textColor="#2E75B6"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvAlerts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="알림 없음"
            android:textSize="13sp"
            android:textColor="#B0BEC5"
            android:maxLines="5" />
    </LinearLayout>

    <!-- 설정 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111D29"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙ 설정"
            android:textSize="12sp"
            android:textColor="#2E75B6"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etServerUrl"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="서버 주소"
            android:textSize="13sp"
            android:textColor="#E0E6ED"
            android:textColorHint="#5A7A96"
            android:background="#0A1118"
            android:padding="8dp"
            android:inputType="textUri"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="설정 저장"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E75B6" />
    </LinearLayout>

</LinearLayout>
