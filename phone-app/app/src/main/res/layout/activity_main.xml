<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1118"
    android:padding="20dp">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="#2E75B6"
            android:text="SP"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SafePulse 관리"
                android:textSize="18sp"
                android:textColor="#E0E6ED"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvConnectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○ 워치 연결 대기"
                android:textSize="12sp"
                android:textColor="#FFB74D" />
        </LinearLayout>
    </LinearLayout>

    <!-- 상태 바 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView android:id="@+id/tvWorkerId" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="14sp" android:textColor="#E0E6ED" android:textStyle="bold" />
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
        <TextView android:id="@+id/tvWatchStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="대기" android:textSize="14sp" android:textColor="#FFB74D" android:textStyle="bold" />
    </LinearLayout>

    <!-- 실시간 바이탈 6칸 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111D29"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <!-- 1행: HR + SpO₂ + 체온 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="#0A1118" android:padding="8dp" android:layout_marginEnd="4dp">
                <TextView android:id="@+id/tvPhoneHR" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="24sp" android:textColor="#FFFFFF" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💓 bpm" android:textSize="10sp" android:textColor="#7A8FA3" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="#0A1118" android:padding="8dp" android:layout_marginEnd="4dp">
                <TextView android:id="@+id/tvPhoneSpO2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--%"  android:textSize="24sp" android:textColor="#FFFFFF" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🫁 SpO₂" android:textSize="10sp" android:textColor="#7A8FA3" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="#0A1118" android:padding="8dp">
                <TextView android:id="@+id/tvPhoneTemp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°"  android:textSize="24sp" android:textColor="#FFFFFF" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌡 체온" android:textSize="10sp" android:textColor="#7A8FA3" />
            </LinearLayout>
        </LinearLayout>

        <!-- 2행: 스트레스 + 베이스라인 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="#0A1118" android:padding="6dp" android:layout_marginEnd="4dp">
                <TextView android:id="@+id/tvPhoneStress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="16sp" android:textColor="#FFFFFF" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="스트레스" android:textSize="9sp" android:textColor="#7A8FA3" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="#0A1118" android:padding="6dp" android:layout_marginEnd="4dp">
                <TextView android:id="@+id/tvPhoneBaseline" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="14sp" android:textColor="#43A047" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="안정HR" android:textSize="9sp" android:textColor="#7A8FA3" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="#0A1118" android:padding="6dp">
                <TextView android:id="@+id/tvSignal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="14sp" android:textColor="#2E75B6" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="활동HR" android:textSize="9sp" android:textColor="#7A8FA3" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ 긴급 상황 카드 (기본 숨김) ═══ -->
    <LinearLayout
        android:id="@+id/emergencyCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111D29"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <!-- 빨간 상단 바 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#E53935"
            android:padding="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🚨 긴급 상황 감지"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmergencyElapsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0초"
                android:textSize="12sp"
                android:textColor="#FFCDD2" />
        </LinearLayout>

        <!-- 바이탈 정보 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvEmergencyHR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="28sp"
                    android:textColor="#E53935"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💓 bpm"
                    android:textSize="10sp"
                    android:textColor="#7A8FA3" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvEmergencySpO2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textSize="28sp"
                    android:textColor="#E0E6ED"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🫁 SpO₂"
                    android:textSize="10sp"
                    android:textColor="#7A8FA3" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvEmergencyState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="응급"
                    android:textSize="16sp"
                    android:textColor="#E53935"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="상태"
                    android:textSize="10sp"
                    android:textColor="#7A8FA3" />
            </LinearLayout>
        </LinearLayout>

        <!-- 버튼들 (발신자: 지도 불필요, 문제없음 + 119만) -->
        <Button
            android:id="@+id/btnPhoneAck"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="✅ 문제 없음 (경보 해제)"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#43A047"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnPhoneDismiss"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="⏹ 오작동 멈추기"
            android:textSize="13sp"
            android:textColor="#B0BEC5"
            android:backgroundTint="#37474F"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnCall119"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="🚨 119 신고"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E53935" />
    </LinearLayout>

    <!-- ═══ 수신자용 P2P 긴급 카드 (기본 숨김) ═══ -->
    <LinearLayout
        android:id="@+id/p2pCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111D29"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E53935"
            android:padding="10dp"
            android:layout_marginBottom="8dp">
            <TextView
                android:id="@+id/tvP2pTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚨 주변 긴급!"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnP2pMap"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📍 사고자 위치 보기"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E75B6"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnP2pDismiss"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="✅ 확인 (알림 종료)"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#43A047" />
    </LinearLayout>

    <!-- 내 건강 리포트 버튼 -->
    <Button
        android:id="@+id/btnHealth"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="📊 내 건강 리포트"
        android:textSize="14sp"
        android:textColor="#2E75B6"
        android:backgroundTint="#111D29"
        android:layout_marginBottom="8dp" />

    <!-- 큰 확인 버튼 (이상 감지 시 사용 — 레거시, 긴급카드로 대체) -->
    <Button
        android:id="@+id/btnAck"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:text="✅ 괜찮아요 (이상 없음)"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#43A047"
        android:layout_marginBottom="12dp"
        android:visibility="gone" />

    <!-- 관제센터 메시지 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111D29"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 관제센터 알림"
            android:textSize="12sp"
            android:textColor="#2E75B6"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvAlerts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="알림 없음"
            android:textSize="13sp"
            android:textColor="#B0BEC5"
            android:maxLines="5" />
    </LinearLayout>

    <!-- 설정 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111D29"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙ 설정"
            android:textSize="12sp"
            android:textColor="#2E75B6"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etServerUrl"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="서버 주소"
            android:textSize="13sp"
            android:textColor="#E0E6ED"
            android:textColorHint="#5A7A96"
            android:background="#0A1118"
            android:padding="8dp"
            android:inputType="textUri"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="설정 저장"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E75B6"
            android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="진동" android:textSize="13sp" android:textColor="#B0BEC5" />
            <Switch android:id="@+id/switchVibration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="소리" android:textSize="13sp" android:textColor="#B0BEC5" />
            <Switch android:id="@+id/switchSound" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
