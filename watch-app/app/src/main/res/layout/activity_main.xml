<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1118"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- 로고 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SafePulse"
            android:textSize="16sp"
            android:textColor="#2E75B6"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <!-- 서버 연결 상태 -->
        <TextView
            android:id="@+id/tvConnection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ 연결 대기"
            android:textSize="10sp"
            android:textColor="#FFB74D" />

        <!-- ═══ 학습 상태 카드 ═══ -->
        <LinearLayout
            android:id="@+id/learningCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111D29"
            android:padding="8dp"
            android:layout_marginTop="6dp"
            android:visibility="visible">

            <TextView
                android:id="@+id/tvLearningTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="베이스라인 학습 중..."
                android:textSize="12sp"
                android:textColor="#2E75B6"
                android:textStyle="bold"
                android:gravity="center" />

            <ProgressBar
                android:id="@+id/pbLearning"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="6dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#2E75B6"
                android:progressBackgroundTint="#1E3044" />

            <TextView
                android:id="@+id/tvLearningTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="남은 시간: 10분 00초"
                android:textSize="14sp"
                android:textColor="#E0E6ED"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvLearningSamples"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="수집된 샘플: 0개"
                android:textSize="10sp"
                android:textColor="#7A8FA3"
                android:gravity="center"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvLearningNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="학습 전에는 기본 데이터로 작동합니다"
                android:textSize="9sp"
                android:textColor="#5A7A96"
                android:gravity="center"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- ═══ 학습 완료 카드 (초기 숨김) ═══ -->
        <LinearLayout
            android:id="@+id/baselineCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111D29"
            android:padding="8dp"
            android:layout_marginTop="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ 개인 베이스라인 학습 완료"
                android:textSize="11sp"
                android:textColor="#43A047"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvBaselineHR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="내 평균 심박: --bpm"
                android:textSize="10sp"
                android:textColor="#E0E6ED"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvBaselineUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="매일 자동 업데이트됩니다"
                android:textSize="9sp"
                android:textColor="#5A7A96"
                android:gravity="center" />
        </LinearLayout>

        <!-- AI 상태 요약 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI 분석 대기중..."
            android:textSize="11sp"
            android:textColor="#B0BEC5"
            android:gravity="center"
            android:background="#111D29"
            android:padding="6dp"
            android:layout_marginTop="6dp" />

        <!-- 심박수 + SpO₂ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#111D29"
                android:padding="6dp"
                android:layout_marginEnd="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💓"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvHeartRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="24sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="bpm"
                    android:textSize="9sp"
                    android:textColor="#7A8FA3" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#111D29"
                android:padding="6dp"
                android:layout_marginStart="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🫁"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvSpO2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textSize="24sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SpO₂"
                    android:textSize="9sp"
                    android:textColor="#7A8FA3" />
            </LinearLayout>
        </LinearLayout>

        <!-- AI 위험도 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111D29"
            android:padding="6dp"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI 위험도"
                android:textSize="9sp"
                android:textColor="#7A8FA3" />

            <TextView
                android:id="@+id/tvRiskLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="안전"
                android:textSize="20sp"
                android:textColor="#66BB6A"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRecommendation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="정상 운영"
                android:textSize="9sp"
                android:textColor="#B0BEC5" />
        </LinearLayout>

        <!-- 알림 배너 -->
        <LinearLayout
            android:id="@+id/alertBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF9800"
            android:padding="6dp"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvLastAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:maxLines="2" />
        </LinearLayout>

        <!-- 알림 내역 버튼 -->
        <Button
            android:id="@+id/btnAlerts"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="관제센터 알림"
            android:textSize="11sp"
            android:textColor="#2E75B6"
            android:backgroundTint="#111D29"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</ScrollView>
